# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
TOP_K=4

# Paths
DATA_DIR=data
CHROMA_DIR=chroma_db
COLLECTION_NAME=documents

# LLM — OpenAI-compatible API (defaults to Ollama)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2
